# =============================================================================
# PIC-SURE All-in-One Configuration
# =============================================================================
# Copy this file to .env and fill in your values.
# Run ./init.sh to generate passwords and self-signed certs.
#
# See GLOSSARY.md for term definitions.
# =============================================================================

# -----------------------------------------------------------------------------
# Auth0 (Required)
# -----------------------------------------------------------------------------
# Get evaluation credentials from: http://avillachlabsupport.hms.harvard.edu
# Select "PIC-SURE All-in-one evaluation client credentials"
AUTH0_CLIENT_ID=
AUTH0_CLIENT_SECRET=
AUTH0_TENANT=avillachlab

# Initial admin user — must be a Google account
ADMIN_EMAIL=

# -----------------------------------------------------------------------------
# Ports
# -----------------------------------------------------------------------------
# Host ports for the frontend (httpd). Change if 80/443 are already in use.
HTTP_PORT=80
HTTPS_PORT=443

# -----------------------------------------------------------------------------
# Auth Mode
# -----------------------------------------------------------------------------
# Three modes (see GLOSSARY.md for details):
#   "open"     — Open PIC-SURE: Discover page without login, no export/API
#   "explore"  — Explore Without Login: query builder without login, export prompts login
#   "required" — Login Required: no access at all without login
AUTH_MODE=required

# Terms of Service — show TOS acceptance dialog on first login
TOS_ENABLED=false

# -----------------------------------------------------------------------------
# Database — Local (default) or Remote
# -----------------------------------------------------------------------------
# For local MySQL (default): leave DB_MODE=local
# For remote MySQL (RDS, etc.): set DB_MODE=remote and fill in connection details
DB_MODE=local
DB_HOST=picsure-db
DB_PORT=3306

# Passwords — generated by init.sh. Do not edit manually.
DB_ROOT_PASSWORD=
DB_PICSURE_PASSWORD=
DB_AUTH_PASSWORD=
DB_AIRFLOW_PASSWORD=

# -----------------------------------------------------------------------------
# HPDS (Data Query Engine)
# -----------------------------------------------------------------------------
# Spring profile — leave empty for phenotypic-only data.
# Set to "bch-dev" ONLY if genomic data has been loaded.
# WARNING: HPDS will crash-loop if set to "bch-dev" without genomic data present.
HPDS_PROFILE=

# JVM tuning
HPDS_JAVA_OPTS="-XX:+UseParallelGC -XX:SurvivorRatio=250 -Xms1g -Xmx16g"

# Data export — 0 disables export, 2000 enables it
HPDS_ID_BATCH_SIZE=2000

# Allow HPDS data file sharing
HPDS_ENABLE_FILE_SHARING=true

# Genomic data settings
HPDS_VCF_EXCERPT_ENABLED=true
HPDS_GENOMIC_DATA_DIRECTORY=/opt/local/hpds/all/

# HPDS tuning
HPDS_CACHE_SIZE=1500
HPDS_SMALL_TASK_THREADS=1
HPDS_LARGE_TASK_THREADS=1
HPDS_SMALL_JOB_LIMIT=100

# -----------------------------------------------------------------------------
# Wildfly (pic-sure-api)
# -----------------------------------------------------------------------------
WILDFLY_JAVA_OPTS="-Xms2g -Xmx4g -XX:MetaspaceSize=96M -XX:MaxMetaspaceSize=256m -Djava.net.preferIPv4Stack=true"

# -----------------------------------------------------------------------------
# PSAMA (Auth Micro-App)
# -----------------------------------------------------------------------------
PSAMA_JAVA_OPTS="-Xms2g -Xmx4g -XX:MetaspaceSize=96M -XX:MaxMetaspaceSize=256m -Djava.net.preferIPv4Stack=true"

# Token expiration (milliseconds)
PSAMA_TOKEN_EXPIRATION=3600000
PSAMA_LONG_TERM_TOKEN_EXPIRATION=2592000000

# Introspection token — generated by init.sh. Do not edit manually.
PICSURE_INTROSPECTION_TOKEN=

# Application UUID — generated by init.sh. Do not edit manually.
PICSURE_APPLICATION_ID=
PICSURE_RESOURCE_ID=

# -----------------------------------------------------------------------------
# Frontend
# -----------------------------------------------------------------------------
# Resource UUIDs (generated by init.sh — used by frontend to target HPDS)
VITE_RESOURCE_HPDS=
VITE_RESOURCE_OPEN_HPDS=

# Theme (maps to frontend CSS theme)
PICSURE_THEME=picsure
VITE_LOGO=

# Auth providers — baked into frontend at build time.
# These are resolved by init.sh from the AUTH0_* values above.
# Changing these requires rebuilding the httpd image.
VITE_AUTH0_TENANT=
VITE_AUTH_PROVIDER_MODULE_GOOGLE=true
VITE_AUTH_PROVIDER_MODULE_GOOGLE_TYPE=AUTH0
VITE_AUTH_PROVIDER_MODULE_GOOGLE_CLIENTID=
VITE_AUTH_PROVIDER_MODULE_GOOGLE_CONNECTION=google-oauth2
VITE_AUTH_PROVIDER_MODULE_GOOGLE_DESCRIPTION=Login

# Feature flags are NOT configured here. They come from the frontend repo's
# .env.example (defaults). build-frontend.sh merges them automatically.
# Only add VITE_* overrides here if you need to change a default for this deployment.

# -----------------------------------------------------------------------------
# Email (Optional)
# -----------------------------------------------------------------------------
# For user activation emails, access request notifications, etc.
# Default SMTP is Gmail. Leave blank to disable outbound email.
EMAIL_USER=
EMAIL_PASSWORD=

# -----------------------------------------------------------------------------
# SSL
# -----------------------------------------------------------------------------
# init.sh generates a self-signed cert in certs/.
# For production, replace with real cert files:
#   certs/server.crt    — certificate
#   certs/server.key    — private key
#   certs/server.chain  — certificate chain

# -----------------------------------------------------------------------------
# Proxy (Optional)
# -----------------------------------------------------------------------------
# Uncomment if running behind a corporate proxy.
# These are passed to Docker builds and container runtime.
# HTTP_PROXY=http://proxy.example.com:8080
# HTTPS_PROXY=http://proxy.example.com:8080
# NO_PROXY=localhost,127.0.0.1,picsure-db,wildfly,psama,httpd,hpds,dictionary-api,dictionary-db

# -----------------------------------------------------------------------------
# Advanced / Rarely Changed
# -----------------------------------------------------------------------------
# Docker image tag for all PIC-SURE services.
# Defaults to "LATEST" if unset. Pin to a specific version for reproducibility.
# PICSURE_IMAGE_TAG=LATEST

# System name shown in UI and emails
SYSTEM_NAME="PIC-SURE All-in-one"

# Release control (legacy — only relevant if using Jenkins for builds)
# RELEASE_CONTROL_REPO=https://github.com/hms-dbmi/baseline-pic-sure-release-control
# RELEASE_CONTROL_BRANCH=main

# Compose project name
COMPOSE_PROJECT_NAME=picsure
