# PIC-SURE Gateway (Phase 1: transparent pass-through)
# Copied/generated to $DOCKER_CONFIG_DIR/gateway/gateway.env by the
# "PIC-SURE Gateway Build and Deploy" Jenkins job on first run.

# Catch-all target: the legacy WildFly (Docker DNS on the picsure network).
WILDFLY_URL=http://wildfly:8080

# Spring profile: aio (default) or local.
SPRING_PROFILE=aio
